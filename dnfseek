#!/bin/bash
# ---------- SAFETY CHECKS ----------
command -v fzf >/dev/null 2>&1 || {
  echo "❌ fzf not installed. Please run: sudo dnf install -y fzf"
  exit 1
}
command -v dnf >/dev/null 2>&1 || {
  echo "❌ dnf not found. This script is for Fedora-based systems."
  exit 1
}

# Isolate fzf from user's custom environment variables
unset FZF_DEFAULT_OPTS FZF_DEFAULT_COMMAND
# Standard options for all fzf menus
fzf_base_opts=(--height=99% --reverse --style=default)

# ---------- CACHE SETUP ----------
CACHE_DIR="$HOME/.cache/dnfseek"
mkdir -p "$CACHE_DIR"

installed_cache="$CACHE_DIR/installed"
available_cache="$CACHE_DIR/available"

update_cache() {
  echo "⏳ Updating package lists..."
  # Use temp files then move to avoid partial reads
  local tmp_inst=$(mktemp)
  local tmp_avail=$(mktemp)

  dnf -q list --installed 2>/dev/null | awk 'NF>=3 && $2 ~ /[0-9.-]/ {print $1}' >"$tmp_inst"
  dnf -q -y --setopt=gpgcheck=1 --setopt=repo_gpgcheck=1 list --available 2>/dev/null | awk 'NF>=3 && $2 ~ /[0-9.-]/ {print $1}' >"$tmp_avail"

  mv "$tmp_inst" "$installed_cache"
  mv "$tmp_avail" "$available_cache"
  echo "✅ Cache updated."
}

cleanup() {
  echo -e "\n👋 Exiting..."
}
trap cleanup EXIT

# Initial cache check: fetch if missing or older than 24h
if [[ ! -f "$installed_cache" || ! -f "$available_cache" ]] ||
  [[ $(find "$installed_cache" -mmin +1440 2>/dev/null) ]]; then
  update_cache
fi

# ---------- MAIN LOOP ----------
while true; do
  # ===== MAIN MENU =====
  mode=$(printf "🔎 Search all packages\n📗 Show installed packages\n🆙 Upgrade all packages\n🔄 Refresh cache\n❌ Quit" |
    fzf "${fzf_base_opts[@]}" \
      --prompt="Main Menu: " \
      --header=$'⬆⬇ Navigate | ⏎ Select | Ctrl-C Quit')

  case "$mode" in
  "❌ Quit" | "") exit 0 ;;
  "📗 Show installed packages") filter_installed=true ;;
  "🔎 Search all packages") filter_installed=false ;;
  "🆙 Upgrade all packages")
    sudo dnf upgrade
    update_cache
    continue
    ;;
  "🔄 Refresh cache")
    update_cache
    continue
    ;;
  esac

  # ===== PACKAGE LIST =====
  if [ "$filter_installed" = true ]; then
    package_list=$(
      awk '{print "\033[32m" $1 " ✅\033[0m"}' "$installed_cache"
    )
  else
    # merge installed + available (color installed green)
    package_list=$(
      {
        awk '{print "\033[32m" $1 " ✅\033[0m"}' "$installed_cache"
        grep -vxFf "$installed_cache" "$available_cache"
      } | sort -u
    )
  fi

  # ===== PACKAGE SELECTION =====
  selected_pkg=$(echo "$package_list" |
    fzf "${fzf_base_opts[@]}" --ansi \
      --prompt="🔎 Search package: " \
      --header=$'⬆⬇ Navigate | ⏎ Select | Ctrl-C Back\n\033[32mGreen = Installed ✅\033[0m | White = Available' \
      --preview 'pkg=$(echo {} | sed "s/ ✅//" | sed "s/\x1b\[[0-9;]*m//g"); dnf info "$pkg" 2>/dev/null | grep -E "^(Name|Summary|Version|Release|Size|URL)"' \
      --preview-window=down:wrap:25%)

  [ -z "$selected_pkg" ] && continue

  # Clean up the package name (remove the checkmark and colors)
  clean_pkg=$(echo "$selected_pkg" | sed "s/ ✅//" | sed "s/\x1b\[[0-9;]*m//g")

  # Check if the cleaned package name is in the installed cache
  if grep -qxF "$clean_pkg" "$installed_cache"; then
    status="installed"
  else
    status="available"
  fi

  # ===== ACTION MENU =====
  if [ "$status" = "installed" ]; then
    action=$(printf "📦 Reinstall\n🗑️ Remove\n⬆️ Update\n🧩 Dependencies\n↩️ Back" |
      fzf "${fzf_base_opts[@]}" \
        --prompt="Choose action: " \
        --header="Selected (installed): $clean_pkg")
  else
    action=$(printf "📦 Install\n🧩 Dependencies\n↩️ Back" |
      fzf "${fzf_base_opts[@]}" \
        --prompt="Choose action: " \
        --header="Selected (available): $clean_pkg")
  fi

  case "$action" in
  "📦 Install")
    sudo dnf install -y "$clean_pkg" && update_cache
    ;;
  "📦 Reinstall")
    sudo dnf reinstall -y "$clean_pkg" && update_cache
    ;;
  "🗑️ Remove")
    sudo dnf remove -y "$clean_pkg" && update_cache
    ;;
  "⬆️ Update")
    sudo dnf upgrade -y "$clean_pkg" && update_cache
    ;;
  "🧩 Dependencies")
    clear
    echo "🔍 Dependencies for $clean_pkg:"
    dnf repoquery --requires "$clean_pkg" 2>/dev/null | sed 's/^/   • /'
    echo -e "\nPress Enter to go back..."
    read
    ;;
  "↩️ Back" | "") continue ;;
  esac
done
